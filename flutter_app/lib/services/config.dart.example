import 'dart:io';
import 'package:shared_preferences/shared_preferences.dart';
import 'package:uuid/uuid.dart';

class Config {
  static const _keyServer    = 'beam_server';
  static const _keyToken     = 'beam_token';
  static const _keyChannel   = 'beam_channel';
  static const _keyDeviceId  = 'beam_device_id';
  static const _defaultServer  = 'http://YOUR_SERVER_IP:8899';  // <-- fill in
  static const _defaultToken   = 'YOUR_AUTH_TOKEN';              // <-- fill in
  static const _defaultChannel = 'default';

  static late SharedPreferences _prefs;

  static Future<void> init() async {
    _prefs = await SharedPreferences.getInstance();
    if (_prefs.getString(_keyDeviceId) == null) {
      final prefix = Platform.isAndroid ? 'android' :
                     Platform.isWindows ? 'windows' :
                     Platform.isMacOS   ? 'mac'     : 'unknown';
      await _prefs.setString(_keyDeviceId, '$prefix-${const Uuid().v4()}');
    }
  }

  static String get server    => _prefs.getString(_keyServer)   ?? _defaultServer;
  static String get token     => _prefs.getString(_keyToken)    ?? _defaultToken;
  static String get channelId => _prefs.getString(_keyChannel)  ?? _defaultChannel;
  static String get deviceId  => _prefs.getString(_keyDeviceId) ?? 'unknown';

  static Future<void> setChannelId(String v) => _prefs.setString(_keyChannel, v);
}
